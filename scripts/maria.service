# M.A.R.I.A. AI Agent - systemd service
# Copy to /etc/systemd/system/maria.service
# Then: sudo systemctl daemon-reload && sudo systemctl enable maria

[Unit]
Description=M.A.R.I.A. AI Agent
After=network.target ollama.service
Wants=ollama.service

[Service]
Type=simple
User=maria
WorkingDirectory=/home/maria/maria
ExecStart=/home/maria/maria/venv/bin/python run_maria.py
Restart=on-failure
RestartSec=10
KillSignal=SIGINT
TimeoutStopSec=30

EnvironmentFile=/home/maria/maria/.env

StandardOutput=journal
StandardError=journal
SyslogIdentifier=maria

[Install]
WantedBy=multi-user.target
