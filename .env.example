# =============================================================================
# M.A.R.I.A. - Environment configuration
# =============================================================================
# Copy this file to .env and edit the values:
#   cp .env.example .env
#   nano .env
#
# NEVER commit your .env file to git!
# =============================================================================

# --- Security ---

# Web UI login PIN (CHANGE this; min 6 characters). install.sh randomizes it.
MARIA_PIN=change-me-123

# Session key (leave empty = auto-generated on start)
# For a stable key: python3 -c "import secrets; print(secrets.token_hex(32))"
MARIA_SECRET_KEY=

# --- Identity ---

# Name Maria calls you until onboarding sets one (used in greetings / prompts)
MARIA_OPERATOR_NAME=Operator

# --- Network ---

# Interface to listen on (0.0.0.0 = all LAN interfaces)
MARIA_HOST=0.0.0.0

# Web UI port
MARIA_PORT=5000

# CORS - defaults to the auto-detected LAN IP
# Example: MARIA_CORS_ORIGINS=http://192.168.1.100:5000
MARIA_CORS_ORIGINS=

# --- Ollama (local LLM) ---

# Ollama API URL (default: localhost)
OLLAMA_BASE_URL=http://localhost:11434

# --- NVIDIA NIM (optional cloud LLM for stronger analysis) ---

# NVIDIA NIM API key (6-month free tier)
NVIDIA_NIM_API_KEY=

# NIM endpoint URL (default: NVIDIA cloud)
NVIDIA_NIM_BASE_URL=https://integrate.api.nvidia.com/v1

# NIM model (default: nemotron 70B)
NVIDIA_NIM_MODEL=nvidia/llama-3.1-nemotron-70b-instruct

# Token limits (daily / monthly)
NIM_DAILY_TOKEN_LIMIT=100000
NIM_MONTHLY_TOKEN_LIMIT=2000000

# Use NIM as the Web UI chat backend (default: false = Ollama)
# Set true to route chat through the stronger NIM model
NIM_CHAT_ENABLED=false

# --- Telegram bot (optional) ---

# Telegram bot token (from @BotFather)
TELEGRAM_BOT_TOKEN=
# Your Telegram chat ID (get it from @userinfobot)
TELEGRAM_CHAT_ID=

# --- Weather (OpenWeatherMap, optional) ---

# OpenWeatherMap API key (free tier: https://openweathermap.org/api)
OPENWEATHERMAP_API_KEY=
# City fallback if not set via /profile (format: "Berlin,DE")
OPENWEATHERMAP_CITY=

# --- Runtime ---

# Debug mode (keep false in production!)
MARIA_DEBUG=false
