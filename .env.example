# =============================================================================
# M.A.R.I.A. - Konfiguracja srodowiska
# =============================================================================
# Skopiuj ten plik jako .env i zmien wartosci:
#   cp .env.example .env
#   nano .env
#
# NIGDY nie commituj pliku .env do gita!
# =============================================================================

# --- Bezpieczenstwo ---

# PIN do Web UI (ZMIEN na wlasny, min 6 znakow!)
MARIA_PIN=zmien-mnie-123

# Klucz sesji (zostaw puste = auto-generowany przy starcie)
# Jesli chcesz staly klucz: python3 -c "import secrets; print(secrets.token_hex(32))"
MARIA_SECRET_KEY=

# --- Siec ---

# Na jakim IP sluchac (0.0.0.0 = wszystkie interfejsy LAN)
MARIA_HOST=0.0.0.0

# Port Web UI
MARIA_PORT=5000

# CORS - domyslnie auto-detekcja LAN IP
# Przyklad: MARIA_CORS_ORIGINS=http://192.168.178.100:5000
MARIA_CORS_ORIGINS=

# --- Ollama ---

# URL Ollama API (domyslnie localhost)
OLLAMA_BASE_URL=http://localhost:11434

# Sciezka do Ollama (auto-detekcja jesli puste)
# OLLAMA_PATH=

# --- NVIDIA NIM ---

# Klucz API do NVIDIA NIM (6-miesieczny darmowy tier)
NVIDIA_NIM_API_KEY=

# URL endpointu NIM (domyslny: NVIDIA cloud)
NVIDIA_NIM_BASE_URL=https://integrate.api.nvidia.com/v1

# Model NIM (domyslny: nemotron 70B)
NVIDIA_NIM_MODEL=nvidia/llama-3.1-nemotron-70b-instruct

# Limity tokenow (dzienne / miesieczne)
NIM_DAILY_TOKEN_LIMIT=100000
NIM_MONTHLY_TOKEN_LIMIT=2000000

# --- Telegram (ClawBot) ---

# Token bota Telegram (od @BotFather)
TELEGRAM_BOT_TOKEN=
# Chat ID operatora (Eryk)
TELEGRAM_CHAT_ID=

# --- Tryb pracy ---

# Debug mode (false na produkcji!)
MARIA_DEBUG=false
