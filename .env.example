# M.A.R.I.A. Environment Configuration
# Copy this file to .env and customize values
# All values shown are defaults

# --- Ollama ---
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_PATH=                # Custom path to ollama binary (auto-detected if empty)

# --- Web UI ---
# MARIA_PIN=1234
# MARIA_SECRET_KEY=           # Auto-generated if empty
# MARIA_DEBUG=false
# MARIA_CORS_ORIGINS=         # Comma-separated, e.g. http://192.168.1.100:5000
# MARIA_HOST=0.0.0.0
# MARIA_PORT=5000
