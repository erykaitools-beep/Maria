# ── Runtime data (generated by Maria during operation) ──
# These directories are created at runtime and should not be committed.
# The public repo ships with empty placeholder dirs.
data/
/memory/
logs/
*.log
*.jsonl

# Runtime state files
semantic_graph.json
maria_learned_concepts.json
maria_report.json

# Meta data (runtime state, personal data, model outputs).
# The whole dir is runtime-generated and nothing here is tracked. A whole-dir
# ignore (instead of per-extension globs) prevents subdir leaks such as
# meta_data/fs_sandbox/*.txt, which slipped past meta_data/*.txt, re-dirtied
# the tree, and blocked the conductor's auto-commit safeguard (2026-06-04).
meta_data/

# Audit workspaces (lab-grade audit runs, local-only working artifacts)
audit/

# Input files (user-provided learning materials)
input/*.txt

# Archive (legacy/deprecated code)
archive/

